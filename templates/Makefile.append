
# ============================================================================
# 多 Agent 工作流命令（由 multi-agent-workflow init.sh 自动添加）
# ============================================================================

.PHONY: dev-up dev-down dev-logs vk vk-stop quality-gate conflict-check post-merge dispatcher-status dispatcher-once

# VK 固定端口（避免每次重启端口变化导致 MCP 需要 Reload Window）
VK_PORT ?= 9527

# ── 主入口：一键启动 VK + Dispatcher，含健康检查和异常通知 ──────────────────
dev-up:
	@bash .vk/dev.sh

# ── 停止 VK 和 Dispatcher ──────────────────────────────────────────────────
dev-down:
	@echo "⏹  停止 Dispatcher..."
	@pkill -f "python.*dispatcher" 2>/dev/null && echo "✓ Dispatcher 已停止" || echo "Dispatcher 未在运行"
	@echo "⏹  停止 VK..."
	@pkill -f "vibe-kanban" 2>/dev/null && echo "✓ VK 已停止" || echo "VK 未在运行"

# ── 查看实时日志 ──────────────────────────────────────────────────────────
dev-logs:
	@tail -f .vk/logs/vk.log .vk/logs/dispatcher.log 2>/dev/null || echo "日志文件尚未生成，请先运行 make dev-up"

# ── 仅启动 VK（不启动 Dispatcher，适合 MCP 调试）────────────────────────
vk:
	@echo "启动 Vibe Kanban（端口 $(VK_PORT)）..."
	PORT=$(VK_PORT) npx vibe-kanban

vk-stop:
	@pkill -f "vibe-kanban" 2>/dev/null && echo "✓ VK 已停止" || echo "VK 未在运行"

# ── 质量门禁和维护命令 ────────────────────────────────────────────────────
quality-gate:
	@bash scripts/agent-quality-gate.sh

conflict-check:
	@bash scripts/check-worktree-conflicts.sh

post-merge:
	@bash scripts/post-merge-verify.sh

dispatcher-status:
	@VK_PORT=$(VK_PORT) python3 -m dispatcher --project-dir . status --cached

dispatcher-once:
	@VK_PORT=$(VK_PORT) python3 -m dispatcher --project-dir . run --once
